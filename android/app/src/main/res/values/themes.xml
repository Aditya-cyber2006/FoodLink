<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FoodBridge" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Disable automatic action bar (we'll use Toolbar instead) -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>

        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary</item>

        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Action bar -->
        <item name="actionBarStyle">@style/AppActionBar</item>
        <item name="actionBarTheme">@style/AppActionBarTheme</item>
    </style>

    <!-- Action Bar Styles -->
    <style name="AppActionBar" parent="Widget.MaterialComponents.AppBarLayout.Primary">
        <item name="elevation">4dp</item>
        <item name="android:background">@color/primary</item>
    </style>

    <style name="AppActionBarTheme" parent="ThemeOverlay.MaterialComponents.ActionBar">
        <item name="colorControlNormal">@color/white</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle.H1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.H2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.H3" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextStyle.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextStyle.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/text_disabled</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="ButtonStyle.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/secondary</item>
        <item name="android:textColor">@color/secondary</item>
    </style>

    <!-- EditText Styles -->
    <style name="EditTextStyle" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxStrokeColor">@color/border</item>
    </style>

    <!-- Card Styles -->
    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:background">@color/white</item>
    </style>

</resources>
