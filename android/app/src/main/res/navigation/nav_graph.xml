<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Home Fragment -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.foodbridge.app.ui.home.HomeFragment"
        android:label="FoodBridge">
        <action
            android:id="@+id/action_home_to_login"
            app:destination="@id/loginFragment">
            <argument
                android:name="selectedRole"
                app:argType="string"
                android:defaultValue="all" />
        </action>
    </fragment>

    <!-- Login Fragment -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.foodbridge.app.ui.login.LoginFragment"
        android:label="Login">
        <argument
            android:name="selectedRole"
            app:argType="string"
            android:defaultValue="all" />
        <action
            android:id="@+id/action_login_to_restaurant_dashboard"
            app:destination="@id/restaurantDashboardFragment" />
        <action
            android:id="@+id/action_login_to_ngo_dashboard"
            app:destination="@id/ngoDashboardFragment" />
        <action
            android:id="@+id/action_login_to_admin_dashboard"
            app:destination="@id/adminDashboardFragment" />
    </fragment>

    <!-- Restaurant Dashboard Fragment -->
    <fragment
        android:id="@+id/restaurantDashboardFragment"
        android:name="com.foodbridge.app.ui.dashboard.RestaurantDashboardFragment"
        android:label="Restaurant Dashboard" />

    <!-- NGO Dashboard Fragment -->
    <fragment
        android:id="@+id/ngoDashboardFragment"
        android:name="com.foodbridge.app.ui.dashboard.NGODashboardFragment"
        android:label="NGO Dashboard" />

    <!-- Admin Dashboard Fragment -->
    <fragment
        android:id="@+id/adminDashboardFragment"
        android:name="com.foodbridge.app.ui.dashboard.AdminDashboardFragment"
        android:label="Admin Dashboard" />

</navigation>
